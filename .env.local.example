# ============================================================================
# StudiaCare environment variables
# Copy this file to `.env.local` and fill in real values.
# The app runs fully WITHOUT these (local demo mode using localStorage);
# fill them in to switch on real Supabase auth and Stripe checkout.
# ============================================================================

# ---- Supabase ----  {{NEED FROM CLIENT: create project, paste URL + anon key}}
# Find these in Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-only, used by API routes for privileged writes (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Stripe ----  {{NEED FROM CLIENT: her Stripe account already exists — paste TEST keys}}
# Find these in Stripe → Developers → API keys (use test keys for drafts)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs from Stripe → Products (create Standard + Advanced recurring prices)
# {{NEED FROM CLIENT: create these products in her Stripe and paste the price IDs}}
NEXT_PUBLIC_STRIPE_PRICE_STANDARD=price_standard_xxx   # $9/mo, first month free (trial)
NEXT_PUBLIC_STRIPE_PRICE_ADVANCED=price_advanced_xxx   # $15/mo

# Where Stripe sends the user back after checkout
NEXT_PUBLIC_SITE_URL=http://localhost:3000
